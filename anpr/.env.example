# anpr/.env.example — copy to anpr/.env and fill in real values. NEVER commit .env.

# FastAPI backend trigger endpoint
API_ENDPOINT=http://localhost:8000/api/v1/gate/trigger

# Long-lived JWT issued by backend/core/security.py → create_anpr_service_token()
# Rotate annually or on suspected compromise
API_SECRET_KEY=REPLACE_WITH_REAL_ANPR_JWT

# Camera settings
CAMERA_INDEX=0           # 0 = built-in webcam, 1 = DroidCam / external USB

# Gate settings — change per physical installation
GATE_ID=G1               # Must match an allowed gate_id in backend models/gate.py
GATE_DIRECTION=entry     # "entry" for entry gates, "exit" for exit gates
