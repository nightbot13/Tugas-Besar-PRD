# frontend/.env.local — never commit this file

# FastAPI backend base URL (HTTP)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI backend WebSocket base URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Dashboard JWT — generate with create_dashboard_token() in core/security.py
# In production, this is delivered by your auth system (e.g. next-auth session)
NEXT_PUBLIC_DASHBOARD_TOKEN=REPLACE_WITH_DASHBOARD_JWT
