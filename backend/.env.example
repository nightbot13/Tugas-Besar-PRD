# backend/.env  — NEVER commit this file. Add it to .gitignore.
# Generate JWT_SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

APP_NAME=ANPR Parking Gate — ITB Jatinangor
APP_VERSION=1.0.0
DEBUG=true

JWT_SECRET_KEY=REPLACE_WITH_32_BYTE_HEX_SECRET
JWT_ALGORITHM=HS256

REDIS_URL=redis://localhost:6379/0
REDIS_COOLDOWN_TTL=10
REDIS_SESSION_TTL=86400

CORS_ORIGINS=["http://localhost:3000"]
GATE_OPEN_DURATION_MS=1000
